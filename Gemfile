# frozen_string_literal: true

source "https://rubygems.org"

gem "roda", "~> 3.0"      # routing-tree web framework (same stack as Ubicloud)
gem "rackup", "~> 2.1"    # config.ru loader for Rack 3 / Puma
gem "puma", "~> 6.4"      # threaded app server (many threads -> many SSE clients)
gem "sequel", "~> 5.0"    # database toolkit
gem "pg", "~> 1.5"        # PostgreSQL driver (+ raw LISTEN/NOTIFY)
gem "base64", "~> 0.2"    # bundled gem on Ruby 3.4+, used to ship the snapshot
